{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the Flash main window, including remote-origin access so useflash.com can call our IPC commands (register_device, etc.).",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://useflash.com",
      "https://*.useflash.com",
      "http://localhost:3000",
      "http://localhost:*"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-is-visible",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "core:event:default",
    "autostart:default"
  ]
}
