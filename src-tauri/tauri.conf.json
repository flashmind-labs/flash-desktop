{
  "$schema": "https://raw.githubusercontent.com/nicohman/tauri-docs/refs/heads/main/src/content/docs/reference/_schemas/config.schema.json",
  "productName": "Flash Desktop",
  "identifier": "com.flashmindlabs.desktop",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "id": "flash-tray",
      "iconPath": "icons/icon.png",
      "tooltip": "Flash Desktop",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "title": "Flash",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "visible": true,
        "center": true,
        "url": "index.html",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
